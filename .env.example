# =============================================================================
# NeuroScan — Environment Variables
# Copy this file to .env and adjust values as needed.
#   cp .env.example .env
# =============================================================================

# ── API Server ──
HOST=0.0.0.0
PORT=8000

# ── Model Path ──
# Path to the ONNX model. Defaults to artifacts/best.onnx relative to the project root.
# MODEL_PATH=artifacts/best.onnx

# ── Development ──
# RELOAD=true  (uvicorn --reload for hot-reloading)
